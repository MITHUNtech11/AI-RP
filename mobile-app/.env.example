# Backend Configuration
# For development with Expo locally, use your machine's IP address on the same WiFi network
# For web platform, localhost:8000 works if backend is running locally
REACT_APP_BACKEND_URL=http://127.0.0.1:8000

# API Authentication
# IMPORTANT: This is sensitive - do NOT commit actual keys to version control
# Get this from your backend administrator or environment setup
REACT_APP_BACKEND_API_KEY=your-actual-api-key-here

# Node Environment (automatically set by Expo/build tools)
# NODE_ENV=development
