# ============================================
# AUTHENTICATION & JWT
# ============================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================
# DATABASE
# ============================================
# SQLite (development):
DATABASE_URL=sqlite:///./resume_parser.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/resume_parser_db

# ============================================
# AI/ML APIS
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# APP CONFIGURATION
# ============================================
API_KEY=your-default-api-key
REQUIRE_AUTH=true
DEBUG=false
APP_NAME=AI Resume Parser API
APP_VERSION=2.1.0

# ============================================
# FILE PROCESSING
# ============================================
MAX_FILE_SIZE_MB=50
ALLOWED_FORMATS=.pdf,.docx,.doc,.jpg,.jpeg,.png,.bmp,.tiff,.jfif

# ============================================
# RATE LIMITING (requests per minute)
# ============================================
RATE_LIMIT_PARSE=10/minute
RATE_LIMIT_BATCH=5/minute
RATE_LIMIT_TEXT=10/minute

# ============================================
# OPTIONAL: SUPABASE (for file storage)
# ============================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-key
